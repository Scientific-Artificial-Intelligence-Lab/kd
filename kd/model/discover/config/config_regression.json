{
  "task": {
    "task_type": "regression",
    "dataset": "regression_dataset",
    "function_set": ["add", "mul", "div", "const"],
    "metric": "inv_nrmse",
    "metric_params": [],
    "threshold": 1e-8
  },
  "gp_agg": {
    "run_gp_agg": false,
    "gp": {},
    "STRidge": {}
  },
  "parameterized": {
    "on": false,
    "validation_type": ""
  },
  "training": {
    "n_epochs": null,
    "n_samples": 20000,
    "batch_size": 1000,
    "epsilon": 0.02,
    "baseline": "R_e",
    "alpha": 0.5,
    "b_jumpstart": false,
    "n_cores_batch": 1,
    "complexity": "length",
    "default_terms": [],
    "const_optimizer": "scipy",
    "const_params": {},
    "verbose": true,
    "debug": 1,
    "early_stopping": true,
    "hof": 10,
    "use_memory": false,
    "memory_capacity": 1e3,
    "warm_start": null,
    "memory_threshold": null,
    "save_all_epoch": false,
